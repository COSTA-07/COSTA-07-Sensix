<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FF Sensi AI Pro Max</title>
  <style>
    :root{
      --bg1:#06070a;
      --bg2:#111826;
      --card: rgba(14, 20, 32, .78);
      --card2: rgba(255,255,255,.06);
      --line: rgba(255,255,255,.12);
      --txt:#f3f6ff;
      --muted:#a9b3c7;
      --accent:#ff3d71;
      --accent2:#00d4ff;
      --accent3:#7c5cff;
      --good:#2de38a;
      --shadow: 0 20px 60px rgba(0,0,0,.45);
      --radius: 24px;
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      font-family: Arial, Helvetica, sans-serif;
      color:var(--txt);
      background:
        radial-gradient(circle at top left, rgba(255,61,113,.22), transparent 28%),
        radial-gradient(circle at top right, rgba(0,212,255,.18), transparent 24%),
        radial-gradient(circle at bottom center, rgba(124,92,255,.16), transparent 30%),
        linear-gradient(135deg, var(--bg1), var(--bg2));
      overflow-x:hidden;
    }

    .wrap{
      width:min(1200px, 94vw);
      margin:0 auto;
      padding:24px 0 40px;
      position:relative;
    }

    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:18px;
      flex-wrap:wrap;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .logo{
      width:54px;
      height:54px;
      border-radius:18px;
      background:
        linear-gradient(135deg, rgba(255,61,113,.95), rgba(124,92,255,.95));
      box-shadow: 0 0 0 1px rgba(255,255,255,.14), 0 10px 30px rgba(255,61,113,.28);
      display:grid;
      place-items:center;
      font-size:28px;
      font-weight:700;
    }

    .title h1{
      margin:0;
      font-size:clamp(24px, 4vw, 42px);
      letter-spacing:.4px;
    }

    .title p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:14px;
    }

    .pill{
      padding:10px 14px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.04);
      color:#dfe7ff;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      font-size:13px;
      white-space:nowrap;
    }

    .hero{
      display:grid;
      grid-template-columns: 1.15fr .85fr;
      gap:18px;
      margin-top:18px;
    }

    .card{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      backdrop-filter: blur(14px);
      overflow:hidden;
      position:relative;
    }

    .card::before{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(120deg, rgba(255,255,255,.06), transparent 28%, rgba(255,255,255,.03));
      pointer-events:none;
    }

    .hero-left{
      padding:22px;
      min-height:520px;
    }

    .hero-banner{
      border-radius:22px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.1);
      background:
        linear-gradient(180deg, rgba(0,0,0,.08), rgba(0,0,0,.55)),
        url("https://images.unsplash.com/photo-1511512578047-dfb367046420?auto=format&fit=crop&w=1400&q=80") center/cover;
      min-height:180px;
      display:flex;
      align-items:flex-end;
      padding:18px;
      margin-bottom:18px;
      position:relative;
    }

    .banner-text{
      max-width:520px;
    }

    .banner-text h2{
      margin:0 0 6px;
      font-size:clamp(22px, 3vw, 34px);
    }

    .banner-text p{
      margin:0;
      color:#eef3ff;
      line-height:1.5;
      font-size:14px;
    }

    .grid{
      display:grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap:14px;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:8px;
      padding:14px;
      background:var(--card2);
      border:1px solid rgba(255,255,255,.08);
      border-radius:18px;
    }

    .field label{
      font-size:13px;
      color:#dfe7ff;
      font-weight:700;
    }

    .field select,
    .field input[type="text"]{
      width:100%;
      border:none;
      outline:none;
      border-radius:14px;
      padding:12px 14px;
      background:rgba(255,255,255,.08);
      color:var(--txt);
      border:1px solid rgba(255,255,255,.08);
    }

    .slider-wrap{
      padding:14px;
      background:var(--card2);
      border:1px solid rgba(255,255,255,.08);
      border-radius:18px;
      grid-column: 1 / -1;
    }

    .slider-top{
      display:flex;
      justify-content:space-between;
      gap:12px;
      margin-bottom:8px;
      font-size:13px;
      color:#dfe7ff;
      font-weight:700;
    }

    input[type="range"]{
      width:100%;
      accent-color: var(--accent);
    }

    .buttons{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      margin-top:16px;
    }

    .btn{
      appearance:none;
      border:none;
      outline:none;
      cursor:pointer;
      padding:13px 18px;
      border-radius:16px;
      color:white;
      font-weight:800;
      letter-spacing:.3px;
      transition:.2s transform, .2s opacity, .2s box-shadow;
      box-shadow: 0 14px 28px rgba(0,0,0,.28);
    }
    .btn:hover{ transform: translateY(-1px); }
    .btn:active{ transform: translateY(1px) scale(.99); }

    .btn-main{
      background: linear-gradient(135deg, var(--accent), #ff8a5b);
    }
    .btn-alt{
      background: linear-gradient(135deg, var(--accent2), var(--accent3));
    }
    .btn-dark{
      background: rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.1);
    }

    .note{
      margin-top:14px;
      color:var(--muted);
      font-size:13px;
      line-height:1.5;
    }

    .hero-right{
      padding:22px;
      display:flex;
      flex-direction:column;
      gap:14px;
    }

    .statbox{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }

    .mini{
      padding:16px;
      border-radius:20px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.05);
    }

    .mini .k{
      color:var(--muted);
      font-size:12px;
      margin-bottom:8px;
    }

    .mini .v{
      font-size:24px;
      font-weight:900;
      letter-spacing:.2px;
    }

    .preview{
      min-height:230px;
      border-radius:22px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.08);
      background:
        linear-gradient(180deg, rgba(0,0,0,.18), rgba(0,0,0,.62)),
        url("https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=1200&q=80") center/cover;
      position:relative;
    }

    .preview .tag{
      position:absolute;
      top:14px;
      left:14px;
      padding:8px 12px;
      border-radius:999px;
      background:rgba(0,0,0,.35);
      border:1px solid rgba(255,255,255,.14);
      font-size:12px;
      backdrop-filter: blur(10px);
    }

    .preview .chip{
      position:absolute;
      bottom:14px;
      left:14px;
      right:14px;
      padding:14px;
      border-radius:18px;
      background:rgba(7,10,17,.66);
      border:1px solid rgba(255,255,255,.12);
      backdrop-filter: blur(12px);
    }

    .preview .chip h3{
      margin:0 0 6px;
      font-size:18px;
    }

    .preview .chip p{
      margin:0;
      color:#dfe7ff;
      font-size:13px;
      line-height:1.5;
    }

    .result{
      margin-top:18px;
      padding:22px;
    }

    .result-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:14px;
    }

    .result-head h2{
      margin:0;
      font-size:22px;
    }

    .result-head .sub{
      color:var(--muted);
      font-size:13px;
    }

    .result-grid{
      display:grid;
      grid-template-columns:repeat(4, minmax(0,1fr));
      gap:12px;
    }

    .sense{
      padding:16px;
      border-radius:18px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
    }

    .sense .label{
      color:var(--muted);
      font-size:12px;
      margin-bottom:8px;
    }

    .sense .value{
      font-size:28px;
      font-weight:900;
    }

    .sense .bar{
      margin-top:12px;
      height:10px;
      border-radius:999px;
      background:rgba(255,255,255,.07);
      overflow:hidden;
    }

    .sense .bar span{
      display:block;
      height:100%;
      border-radius:999px;
      background:linear-gradient(90deg, var(--accent2), var(--accent), #ffb36b);
      width:50%;
    }

    .history{
      margin-top:18px;
      padding:22px;
    }

    .history h3{
      margin:0 0 12px;
      font-size:18px;
    }

    .history-list{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:12px;
    }

    .history-item{
      padding:14px;
      border-radius:16px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
      font-size:13px;
      color:#eaf0ff;
      line-height:1.6;
    }

    .footer{
      margin-top:18px;
      color:var(--muted);
      font-size:12px;
      text-align:center;
      padding:8px 0 2px;
    }

    .glow{
      position:absolute;
      inset:auto;
      width:320px;
      height:320px;
      border-radius:50%;
      filter:blur(80px);
      opacity:.18;
      pointer-events:none;
    }
    .glow.a{ background:var(--accent); top:120px; right:-120px; }
    .glow.b{ background:var(--accent2); bottom:20px; left:-100px; }

    @media (max-width: 980px){
      .hero{ grid-template-columns:1fr; }
      .result-grid{ grid-template-columns:repeat(2, minmax(0,1fr)); }
      .history-list{ grid-template-columns:1fr; }
    }

    @media (max-width: 620px){
      .grid{ grid-template-columns:1fr; }
      .result-grid{ grid-template-columns:1fr; }
      .hero-left, .hero-right, .result, .history{ padding:16px; }
      .topbar{ gap:10px; }
      .pill{ width:100%; text-align:center; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="glow a"></div>
    <div class="glow b"></div>

    <div class="topbar">
      <div class="brand">
        <div class="logo">FF</div>
        <div class="title">
          <h1>Sensi AI Pro Max</h1>
          <p>Generador gamer para Free Fire con estilo IA, fotos y diseño premium.</p>
        </div>
      </div>
      <div class="pill">Modo: Ultra Random + anti repetición</div>
    </div>

    <section class="hero">
      <div class="card hero-left">
        <div class="hero-banner">
          <div class="banner-text">
            <h2>Tu generador de sensibilidades, pero más pro</h2>
            <p>
              El motor usa números aleatorios con semilla extra para que cambien cada vez.
              Además evita repetir la última combinación exacta generada.
            </p>
          </div>
        </div>

        <div class="grid">
          <div class="field">
            <label for="perfil">Perfil de juego</label>
            <select id="perfil">
              <option value="preciso">Preciso</option>
              <option value="agresivo">Agresivo</option>
              <option value="mixto" selected>Mixto</option>
              <option value="rush">Rush</option>
            </select>
          </div>

          <div class="field">
            <label for="nivel">Nivel del jugador</label>
            <select id="nivel">
              <option value="novato">Novato</option>
              <option value="medio" selected>Medio</option>
              <option value="pro">Pro</option>
            </select>
          </div>

          <div class="field">
            <label for="nombre">Tu nombre gamer</label>
            <input id="nombre" type="text" placeholder="Ej: Costa' 07" />
          </div>

          <div class="field">
            <label for="tema">Tema visual</label>
            <select id="tema">
              <option value="neon" selected>Neón</option>
              <option value="fire">Fuego</option>
              <option value="ice">Hielo</option>
              <option value="dark">Oscuro</option>
            </select>
          </div>

          <div class="slider-wrap">
            <div class="slider-top">
              <span>Intensidad de la IA</span>
              <span id="nivelIA">78%</span>
            </div>
            <input id="iaLevel" type="range" min="35" max="100" value="78" />
          </div>
        </div>

        <div class="buttons">
          <button class="btn btn-main" id="btnGenerar">Generar sensibilidad</button>
          <button class="btn btn-alt" id="btnCopiar">Copiar resultado</button>
          <button class="btn btn-dark" id="btnLimpiar">Limpiar historial</button>
        </div>

        <div class="note">
          Esto es una IA simulada con lógica aleatoria inteligente. Si después quieres una IA real con API,
          se le puede conectar fácil.
        </div>
      </div>

      <div class="card hero-right">
        <div class="statbox">
          <div class="mini">
            <div class="k">Sesiones</div>
            <div class="v" id="sesiones">0</div>
          </div>
          <div class="mini">
            <div class="k">Última precisión</div>
            <div class="v" id="precision">--</div>
          </div>
        </div>

        <div class="preview">
          <div class="tag">Free Fire Style</div>
          <div class="chip">
            <h3 id="chipTitulo">Listo para generar</h3>
            <p id="chipTexto">Presiona el botón y te doy una configuración única.</p>
          </div>
        </div>

        <div class="mini">
          <div class="k">Tips rápidos</div>
          <div class="v" style="font-size:16px; line-height:1.6; font-weight:700;">
            • Cambia perfil<br>
            • Ajusta la IA<br>
            • Copia tu sensibilidad
          </div>
        </div>
      </div>
    </section>

    <section class="card result">
      <div class="result-head">
        <div>
          <h2>Resultado generado</h2>
          <div class="sub" id="resultadoMeta">Aún no has generado una sensibilidad.</div>
        </div>
        <div class="pill" id="estado">Esperando generación</div>
      </div>

      <div class="result-grid" id="resultGrid">
        <div class="sense">
          <div class="label">General</div>
          <div class="value">--</div>
          <div class="bar"><span style="width:0%"></span></div>
        </div>
        <div class="sense">
          <div class="label">Mira roja</div>
          <div class="value">--</div>
          <div class="bar"><span style="width:0%"></span></div>
        </div>
        <div class="sense">
          <div class="label">2X / 4X</div>
          <div class="value">--</div>
          <div class="bar"><span style="width:0%"></span></div>
        </div>
        <div class="sense">
          <div class="label">AWM / Sniper</div>
          <div class="value">--</div>
          <div class="bar"><span style="width:0%"></span></div>
        </div>
      </div>
    </section>

    <section class="card history">
      <h3>Historial reciente</h3>
      <div class="history-list" id="historyList">
        <div class="history-item">Todavía no hay resultados guardados.</div>
      </div>
    </section>

    <div class="footer">
      Hecho para copiar y pegar en tu web. Fondo, fotos, animación y generador de sensibilidad incluido.
    </div>
  </div>

  <script>
    const perfilEl = document.getElementById('perfil');
    const nivelEl = document.getElementById('nivel');
    const nombreEl = document.getElementById('nombre');
    const temaEl = document.getElementById('tema');
    const iaLevelEl = document.getElementById('iaLevel');
    const nivelIAText = document.getElementById('nivelIA');

    const btnGenerar = document.getElementById('btnGenerar');
    const btnCopiar = document.getElementById('btnCopiar');
    const btnLimpiar = document.getElementById('btnLimpiar');

    const resultGrid = document.getElementById('resultGrid');
    const historyList = document.getElementById('historyList');
    const sesionesEl = document.getElementById('sesiones');
    const precisionEl = document.getElementById('precision');
    const chipTitulo = document.getElementById('chipTitulo');
    const chipTexto = document.getElementById('chipTexto');
    const resultadoMeta = document.getElementById('resultadoMeta');
    const estadoEl = document.getElementById('estado');

    let historial = JSON.parse(localStorage.getItem('ff_sensi_historial') || '[]');
    let sesiones = Number(localStorage.getItem('ff_sensi_sesiones') || 0);

    function randInt(min, max){
      const range = max - min + 1;
      const arr = new Uint32Array(1);
      crypto.getRandomValues(arr);
      return min + (arr[0] % range);
    }

    function clamp(n, min, max){
      return Math.max(min, Math.min(max, n));
    }

    function hashString(str){
      let h = 0;
      for (let i = 0; i < str.length; i++){
        h = ((h << 5) - h) + str.charCodeAt(i);
        h |= 0;
      }
      return Math.abs(h);
    }

    function buildTheme(theme){
      const root = document.documentElement;
      if(theme === 'fire'){
        root.style.setProperty('--accent', '#ff3d71');
        root.style.setProperty('--accent2', '#ff9f1c');
        root.style.setProperty('--accent3', '#ff5c8a');
      } else if(theme === 'ice'){
        root.style.setProperty('--accent', '#00d4ff');
        root.style.setProperty('--accent2', '#6ef3ff');
        root.style.setProperty('--accent3', '#7c5cff');
      } else if(theme === 'dark'){
        root.style.setProperty('--accent', '#7c5cff');
        root.style.setProperty('--accent2', '#2de38a');
        root.style.setProperty('--accent3', '#00d4ff');
      } else {
        root.style.setProperty('--accent', '#ff3d71');
        root.style.setProperty('--accent2', '#00d4ff');
        root.style.setProperty('--accent3', '#7c5cff');
      }
    }

    function getProfileWeights(perfil, nivel, ia){
      const levelBoost = {
        novato: -6,
        medio: 0,
        pro: 7
      }[nivel] || 0;

      const profileBoost = {
        preciso:  -4,
        agresivo:  8,
        mixto:     2,
        rush:      10
      }[perfil] || 0;

      const base = clamp(50 + levelBoost + profileBoost + Math.floor((ia - 50) / 4), 25, 95);
      return base;
    }

    function uniqueProfileSignature(values){
      return `${values.general}-${values.red}-${values.twoX}-${values.awm}-${values.dpi}`;
    }

    function generateSensitivity(){
      const perfil = perfilEl.value;
      const nivel = nivelEl.value;
      const nombre = (nombreEl.value || 'Jugador').trim();
      const tema = temaEl.value;
      const ia = Number(iaLevelEl.value);

      buildTheme(tema);

      const base = getProfileWeights(perfil, nivel, ia);
      const seed = hashString(`${perfil}|${nivel}|${nombre}|${tema}|${ia}|${Date.now()}|${Math.random()}`);

      let general, red, twoX, awm, dpi, accel;

      // Motor “IA” simple: mezcla de base + ruido aleatorio + perfil
      general = clamp(base + randInt(-12, 12) + (seed % 7) - 3, 20, 100);
      red     = clamp(general + randInt(-4, 8), 20, 100);
      twoX    = clamp(general - randInt(4, 14), 20, 100);
      awm     = clamp(twoX - randInt(6, 18), 10, 100);
      dpi     = clamp(480 + randInt(0, 6) * 20 + (perfil === 'rush' ? 40 : 0) + (nivel === 'pro' ? 60 : 0), 320, 1000);
      accel   = clamp(randInt(1, 10) + Math.floor(ia / 20), 1, 15);

      // Evita repetir la última combinación exacta
      const newSig = uniqueProfileSignature({ general, red, twoX, awm, dpi });
      const lastSig = historial[0]?.sig;
      if (newSig === lastSig){
        general = clamp(general + randInt(1, 4), 20, 100);
        red     = clamp(red + randInt(1, 5), 20, 100);
        twoX    = clamp(twoX + randInt(1, 4), 20, 100);
        awm     = clamp(awm + randInt(1, 3), 10, 100);
        dpi     = clamp(dpi + 20, 320, 1000);
      }

      const precisionScore = clamp(
        Math.round(
          45
          + (100 - Math.abs(60 - general